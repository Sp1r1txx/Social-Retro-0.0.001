{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "display_name": { "type": "string" },
        "bio": { "type": "string" },
        "profile_pic": { "type": "string" },
        "custom_bg": { "type": "string" },
        "custom_color": { "type": "string" },
        "security_question": { "type": "string" },
        "security_answer": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "display_name"]
    },
    "Post": {
      "title": "Post",
      "description": "A post in the feed",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "display_name": { "type": "string" },
        "profile_pic": { "type": "string" },
        "image_url": { "type": "string" },
        "caption": { "type": "string" },
        "likes_count": { "type": "number" },
        "comments_count": { "type": "number" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "image_url", "created_at"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a post",
      "type": "object",
      "properties": {
        "post_id": { "type": "string" },
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "display_name": { "type": "string" },
        "profile_pic": { "type": "string" },
        "content": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["post_id", "uid", "content", "created_at"]
    },
    "Message": {
      "title": "Message",
      "description": "A direct message between users",
      "type": "object",
      "properties": {
        "sender_id": { "type": "string" },
        "receiver_id": { "type": "string" },
        "content": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["sender_id", "receiver_id", "content", "created_at"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Feed posts"
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on posts"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Direct messages"
    }
  }
}
